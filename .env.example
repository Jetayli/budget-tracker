# ===========================================
# Budget Tracker - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# Database Configuration
# Use Supabase Transaction Pooler (port 6543) for serverless environments
# Format: postgresql://postgres.[project-ref]:[password]@[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@[REGION].pooler.supabase.com:6543/postgres

# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Frontend environment variables (Vite requires VITE_ prefix)
VITE_SUPABASE_URL=https://[PROJECT_REF].supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Server Configuration
PORT=5000
NODE_ENV=development
